{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

echo '[Setting defaults - Codex]'

theme_file="${HOME}/.codex/codex-theme.json"
state_file="${HOME}/.codex/.codex-global-state.json"
tmp_file="$(mktemp)"

cleanup() {
  rm -f "$tmp_file"
}
trap cleanup EXIT

if [[ ! -f "$theme_file" ]]; then
  echo "Skipping Codex theme sync; missing ${theme_file}"
  exit 0
fi

mkdir -p "$(dirname "$state_file")"

if [[ ! -f "$state_file" ]]; then
  echo "Skipping Codex theme sync; launch Codex once so it can create ${state_file}"
  exit 0
fi

jq --slurpfile theme "$theme_file" '
  .appearanceLightChromeTheme =
    ((.appearanceLightChromeTheme // {}) * ($theme[0].appearanceLightChromeTheme // {}))
  | .appearanceDarkChromeTheme =
    ((.appearanceDarkChromeTheme // {}) * ($theme[0].appearanceDarkChromeTheme // {}))
' "$state_file" > "$tmp_file"

mv "$tmp_file" "$state_file"
{{ end -}}
